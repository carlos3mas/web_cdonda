// Esquema de base de datos para Campus CD Onda

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Inscripcion {
  id                        String   @id @default(cuid())
  tipoInscripcion           String   @default("campus-navidad") // campus-navidad, campus-verano, anual, etc.
  nombreJugador             String
  apellidos                 String
  fechaNacimiento           DateTime
  dni                       String
  direccion                 String?
  localidad                 String?
  codigoPostal              String?
  semanasCampus             String?
  diasSueltos               String?
  tallaCamiseta             String?
  tallaPantalon             String?
  tallaCalcetines           String?
  nombreTutor               String
  telefono1                 String
  telefono2                 String?
  enfermedad                String?
  medicacion                String?
  alergico                  String?
  numeroSeguridadSocial     String?
  pagada                    Boolean  @default(false)
  cuota1Pagada              Boolean  @default(false)
  cuota2Pagada              Boolean  @default(false)
  cuota3Pagada              Boolean  @default(false)
  justificantePago          String?  // Base64 del justificante de pago
  justificantePagoMimeType  String?  // Tipo MIME del justificante (image/jpeg, application/pdf, etc.)
  nombreArchivoJustificante String?  // Nombre original del archivo
  justificantePagoCuota2    String?
  justificantePagoCuota2MimeType String?
  nombreArchivoJustificanteCuota2 String?
  justificantePagoCuota3    String?
  justificantePagoCuota3MimeType String?
  nombreArchivoJustificanteCuota3 String?
  firma                     String?  // Base64 de la firma del tutor
  firmaMimeType             String?  // Tipo MIME de la firma
  nombreArchivoFirma        String?  // Nombre original del archivo de firma
  derechosImagen            Boolean  @default(false)
  comentarios               String?
  // Campos exclusivos de inscripción anual
  email                     String?
  sexo                      String?  // M / F
  categoria                 String?  // chupetines | querubines | futbol-8 | futbol-11
  modalidadPago             String?  // unico | fraccionado
  descuentoHermanos         String?  // no | 2-hermanos | 3-hermanos
  dniFrontalEncriptado      String?  // AES-256-GCM base64 (foto frontal DNI)
  dniFrontalMimeType        String?
  dniReversoEncriptado      String?  // AES-256-GCM base64 (foto reverso DNI)
  dniReversoMimeType        String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("inscripciones")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model PlantillaPDF {
  id              String   @id @default(cuid())
  tipoInscripcion String   @unique // campus-navidad, campus-verano, anual
  nombreArchivo   String
  rutaArchivo     String
  activa          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("plantillas_pdf")
}

